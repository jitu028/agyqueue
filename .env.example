# AgyQueue Environment Configuration Template

# 1. Transport & Service Config
# Supported transports: "stdio" (default for IDE plugins) or "sse" (for microservice/cloud run)
AGYQUEUE_TRANSPORT=sse
PORT=8000
HOST=127.0.0.1

# 2. Database Storage Backend
# For Local/Dev: SQLite database file path (default is agyqueue.db)
AGYQUEUE_DB_PATH=agyqueue.db

# For Production: PostgreSQL Connection URL (automatically activates PostgreSQLTaskStore and Threaded Connection Pool)
# DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/agyqueue

# 3. Message Broker Queue Backend
# For Local/Dev: Leave unset to use default SQLite-backed FIFO queue
# For Production: Redis connection URL (automatically activates RedisTaskQueue)
# REDIS_URL=redis://localhost:6379/0

# 4. Pluggable Notifications (Slack webhook and Email SMTP)
# Enable notifications channels (comma-separated list, e.g. "slack,email")
AGYQUEUE_NOTIFICATIONS=slack,email

# Slack Configuration
SLACK_WEBHOOK_URL=https://example.com/slack-webhook-url

# Email SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@agyqueue.internal
SMTP_TO=recipient-alert-inbox@domain.com

# 5. LLM Agent SDK (Used for client examples testing)
# GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere
